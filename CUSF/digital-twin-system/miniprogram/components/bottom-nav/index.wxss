.acs-nav-wrap {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 60;
  padding: 0 12rpx;
}

.acs-nav-card {
  background: rgba(255, 255, 255, 0.97);
  border: 1rpx solid rgba(11, 129, 255, 0.1);
  border-bottom: 0;
  border-top-left-radius: 28rpx;
  border-top-right-radius: 28rpx;
  box-shadow: 0 -8rpx 32rpx rgba(15, 30, 80, 0.10);
  backdrop-filter: blur(16px);
}

.acs-nav-row {
  height: 116rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 8rpx;
}

.acs-nav-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  color: #9ba4bb;
  padding: 10rpx 0;
  transition: color 0.18s;
}

.acs-nav-char-wrap {
  width: 52rpx;
  height: 52rpx;
  border-radius: 16rpx;
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.acs-nav-icon {
  width: 42rpx;
  height: 42rpx;
}

.acs-nav-label {
  font-size: 20rpx;
  line-height: 1;
  font-weight: 500;
  transition: color 0.18s;
}

.acs-nav-item.is-active {
  color: var(--color-primary, #0b81ff);
}

.acs-nav-char-wrap.is-active {
  background: transparent;
  transform: scale(1.1) translateY(-2rpx);
}

.acs-nav-item.is-active .acs-nav-label {
  color: var(--color-primary, #0b81ff);
  font-weight: 700;
}

.acs-nav-safe {
  height: 0;
  height: constant(safe-area-inset-bottom);
  height: env(safe-area-inset-bottom);
}
