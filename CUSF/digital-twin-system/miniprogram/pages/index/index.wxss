
page {
  background-color: #09090b;
}

.sp-page {
  min-height: 100vh;
  padding: 24rpx 22rpx 40rpx;
  padding-top: 116rpx;
  padding-top: calc(constant(safe-area-inset-top) + 116rpx);
  padding-top: calc(env(safe-area-inset-top) + 116rpx);
  background: radial-gradient(circle at top right, #1e1b4b 0%, #09090b 45%, #000000 100%);
  color: #fafafa;
  box-sizing: border-box;
}

.sp-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 30;
  background: #000000;
}

.sp-nav-safe {
  height: 0;
  height: constant(safe-area-inset-top);
  height: env(safe-area-inset-top);
}

.sp-nav-bar {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 220rpx 0 120rpx;
  box-sizing: border-box;
}

.sp-nav-title {
  display: none;
}

.sp-card,
.sp-conn-card,
.sp-status-card {
  background: rgba(24, 24, 27, 0.65);
  backdrop-filter: blur(20px) saturate(150%);
  -webkit-backdrop-filter: blur(20px) saturate(150%);
  border-radius: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.5), inset 0 1rpx 0 rgba(255, 255, 255, 0.05);
  transition: transform 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
}

.sp-header {
  margin-bottom: 16rpx;
  padding: 8rpx 4rpx;
}

.sp-brand-row {
  display: flex;
  align-items: center;
}

.sp-brand-dot {
  width: 16rpx;
  height: 16rpx;
  margin-right: 12rpx;
  border-radius: 50%;
  background: #1ed760;
  box-shadow: 0 0 12rpx rgba(30, 215, 96, 0.48);
}

.sp-brand {
  font-size: 30rpx;
  font-weight: 700;
  letter-spacing: 1.5rpx;
}

.sp-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #b3b3b3;
}

.sp-conn-card {
  margin-bottom: 16rpx;
  padding: 18rpx 20rpx;
  border-color: #4d4d4d;
}

.sp-conn-main {
  display: flex;
  align-items: center;
}

.sp-conn-dot {
  margin-right: 10rpx;
  font-size: 22rpx;
}

.sp-conn-state {
  font-size: 24rpx;
  font-weight: 700;
}

.sp-conn-endpoint {
  display: block;
  margin-top: 6rpx;
  font-size: 20rpx;
  color: #9f9f9f;
  word-break: break-all;
}

.sp-conn-card.conn-connected {
  border-color: #1ed760;
}

.sp-conn-card.conn-connected .sp-conn-dot,
.sp-conn-card.conn-connected .sp-conn-state {
  color: #1ed760;
}

.sp-conn-card.conn-connecting {
  border-color: #ffa42b;
}

.sp-conn-card.conn-connecting .sp-conn-dot,
.sp-conn-card.conn-connecting .sp-conn-state {
  color: #ffa42b;
}

.sp-conn-card.conn-disconnected {
  border-color: #f3727f;
}

.sp-conn-card.conn-disconnected .sp-conn-dot,
.sp-conn-card.conn-disconnected .sp-conn-state {
  color: #f3727f;
}

.sp-metric-grid {
  display: flex;
  flex-wrap: wrap;
  margin: 0 -6rpx 16rpx;
}

.sp-metric-card {
  width: calc(50% - 12rpx);
  margin: 0 6rpx 12rpx;
  padding: 18rpx;
  box-sizing: border-box;
}

.sp-metric-label {
  display: block;
  margin-bottom: 10rpx;
  font-size: 20rpx;
  font-weight: 700;
  color: #b3b3b3;
  letter-spacing: 1.3rpx;
}

.sp-metric-value {
  display: block;
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1.15;
  transition: transform 180ms ease, color 180ms ease, text-shadow 180ms ease;
}

.sp-temp {
  color: #f87171;
  text-shadow: 0 0 16rpx rgba(248, 113, 113, 0.3);
}

.sp-humi {
  color: #34d399;
  text-shadow: 0 0 16rpx rgba(52, 211, 153, 0.3);
}

.sp-air {
  color: #60a5fa;
  text-shadow: 0 0 16rpx rgba(96, 165, 250, 0.3);
}

.pulse-up {
  animation: metricPulseUp 240ms ease-out;
}

.pulse-down {
  animation: metricPulseDown 240ms ease-out;
}

@keyframes metricPulseUp {
  0% {
    transform: translateY(0);
    text-shadow: 0 0 0 rgba(30, 215, 96, 0);
  }
  45% {
    transform: translateY(-2rpx);
    text-shadow: 0 0 12rpx rgba(30, 215, 96, 0.5);
  }
  100% {
    transform: translateY(0);
    text-shadow: 0 0 0 rgba(30, 215, 96, 0);
  }
}

@keyframes metricPulseDown {
  0% {
    transform: translateY(0);
    text-shadow: 0 0 0 rgba(83, 157, 245, 0);
  }
  45% {
    transform: translateY(2rpx);
    text-shadow: 0 0 12rpx rgba(83, 157, 245, 0.5);
  }
  100% {
    transform: translateY(0);
    text-shadow: 0 0 0 rgba(83, 157, 245, 0);
  }
}

.sp-status-card {
  margin-bottom: 16rpx;
  padding: 18rpx 20rpx;
  border-color: #4d4d4d;
}

.sp-status-text {
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.35;
  letter-spacing: 1.2rpx;
}

.sp-status-card.status-normal {
  border-color: #1ed760;
}

.sp-status-card.status-normal .sp-status-text {
  color: #1ed760;
}

.sp-status-card.status-temp,
.sp-status-card.status-alert {
  border-color: #f3727f;
}

.sp-status-card.status-temp .sp-status-text,
.sp-status-card.status-alert .sp-status-text {
  color: #f3727f;
}

.sp-status-card.status-humidity {
  border-color: #ffa42b;
}

.sp-status-card.status-humidity .sp-status-text {
  color: #ffa42b;
}

.sp-status-card.status-cooling {
  border-color: #539df5;
}

.sp-status-card.status-cooling .sp-status-text {
  color: #539df5;
}

.sp-status-card.status-waiting .sp-status-text {
  color: #b3b3b3;
}

.sp-leak-card,
.sp-meta-card,
.sp-anomaly-card,
.sp-alarm-card,
.sp-log-card {
  margin-bottom: 16rpx;
  padding: 18rpx 20rpx;
}

.sp-leak-card.sp-ok {
  border-color: #1ed760;
}

.sp-leak-card.sp-alert {
  border-color: #f3727f;
}

.sp-panel-title {
  display: block;
  margin-bottom: 14rpx;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 1.3rpx;
}

.sp-leak-text {
  display: block;
  margin-top: 4rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.sp-leak-card.sp-ok .sp-leak-text {
  color: #1ed760;
}

.sp-leak-card.sp-alert .sp-leak-text {
  color: #f3727f;
}

.sp-meta-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.sp-meta-key {
  font-size: 20rpx;
  font-weight: 700;
  color: #b3b3b3;
}

.sp-meta-val {
  font-size: 20rpx;
  color: #ffffff;
}

.sp-ok {
  color: #1ed760;
}

.sp-alert {
  color: #f3727f;
}

.sp-meta-summary {
  display: block;
  margin-top: 10rpx;
  padding-top: 10rpx;
  border-top: 1rpx solid #2a2a2a;
  font-size: 20rpx;
  color: #b3b3b3;
  line-height: 1.45;
}

.sp-control-wrap {
  margin-bottom: 16rpx;
}

.sp-btn-primary {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 9999rpx;
  border: none;
  background: linear-gradient(135deg, #10b981 0%, #3b82f6 100%);
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  box-shadow: 0 8rpx 20rpx rgba(16, 185, 129, 0.35);
  transition: transform 180ms ease, background-color 180ms ease, opacity 180ms ease;
}

.sp-btn-primary::after {
  border: none;
}

.sp-btn-primary:active {
  transform: scale(0.975);
  box-shadow: 0 4rpx 10rpx rgba(16, 185, 129, 0.25);
}

.sp-btn-primary.sp-btn-disabled {
  background: #1f1f1f;
  color: #7c7c7c;
  box-shadow: inset 0 0 0 1rpx #4d4d4d;
}

.sp-hint {
  display: block;
  margin-top: 8rpx;
  padding-left: 8rpx;
  font-size: 18rpx;
  color: #b3b3b3;
  line-height: 1.4;
}

.sp-mode-card {
  margin-top: 12rpx;
  margin-bottom: 10rpx;
  padding: 16rpx 18rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.03);
}

.sp-mode-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.sp-mode-head .sp-panel-title {
  margin-bottom: 0;
}

.sp-mode-badge {
  padding: 4rpx 16rpx;
  border-radius: 9999rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  font-size: 19rpx;
  font-weight: 700;
  color: #a1a1aa;
}

.sp-mode-badge.auto {
  border-color: rgba(16, 185, 129, 0.4);
  color: #10b981;
  background: rgba(16, 185, 129, 0.1);
}

.sp-mode-badge.manual {
  border-color: rgba(59, 130, 246, 0.4);
  color: #3b82f6;
  background: rgba(59, 130, 246, 0.1);
}

.sp-mode-switch {
  display: flex;
  margin: 0 -4rpx;
}

.sp-toggle-btn {
  flex: 1;
  margin: 0 4rpx;
  height: 62rpx;
  line-height: 62rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.04);
  color: #a1a1aa;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  font-size: 21rpx;
  font-weight: 600;
  transition: all 160ms ease;
}

.sp-toggle-btn::after {
  border: none;
}

.sp-toggle-btn:active {
  transform: scale(0.975);
}

.sp-toggle-btn.on {
  border-color: rgba(16, 185, 129, 0.5);
  color: #10b981;
  background: rgba(16, 185, 129, 0.1);
  box-shadow: 0 4rpx 12rpx rgba(16, 185, 129, 0.15);
}

.sp-toggle-btn.disabled {
  opacity: 0.5;
}

.sp-eq-grid {
  display: flex;
  flex-wrap: wrap;
  margin: 10rpx -4rpx 0;
}

.sp-eq-item {
  width: calc(50% - 8rpx);
  margin: 0 4rpx 8rpx;
  padding: 12rpx 14rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  box-sizing: border-box;
  transition: all 180ms ease;
}

.sp-eq-item.mode-auto {
  border-color: rgba(16, 185, 129, 0.3);
  box-shadow: inset 0 0 16rpx rgba(16, 185, 129, 0.05);
}

.sp-eq-item.mode-manual {
  border-color: rgba(59, 130, 246, 0.3);
  box-shadow: inset 0 0 16rpx rgba(59, 130, 246, 0.05);
}

.sp-eq-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.sp-eq-name {
  font-size: 18rpx;
  font-weight: 700;
  color: #f2f2f2;
}

.sp-eq-mode,
.sp-eq-state,
.sp-eq-power {
  font-size: 17rpx;
  color: #b3b3b3;
}

.sp-eq-state {
  margin-top: 4rpx;
}

.sp-eq-bar {
  margin-top: 6rpx;
  height: 6rpx;
  background: #2a2a2a;
  border-radius: 9999rpx;
  overflow: hidden;
}

.sp-eq-fill {
  height: 100%;
  border-radius: 9999rpx;
  background: linear-gradient(90deg, #10b981 0%, #06b6d4 50%, #3b82f6 100%);
  transition: width 220ms ease;
}

.sp-notice {
  margin-top: 10rpx;
  padding: 10rpx 12rpx;
  border-radius: 12rpx;
  border: 1rpx solid #3a3a3a;
  font-size: 18rpx;
  line-height: 1.4;
  color: #b3b3b3;
  background: #191919;
}

.sp-notice.info {
  border-color: rgba(105, 182, 255, 0.45);
  color: #9fcbff;
}

.sp-notice.alert {
  border-color: rgba(243, 114, 127, 0.45);
  color: #ffb4bc;
}

.sp-notice.success {
  border-color: rgba(30, 215, 96, 0.45);
  color: #aef1c6;
}

.sp-panel-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 10rpx;
}

.sp-action-group {
  display: flex;
  align-items: center;
}

.sp-mini-btn {
  height: 52rpx;
  line-height: 52rpx;
  padding: 0 22rpx;
  border-radius: 9999rpx;
  background: rgba(255, 255, 255, 0.08);
  color: #fafafa;
  border: 1rpx solid rgba(255, 255, 255, 0.15);
  font-size: 19rpx;
  font-weight: 600;
  margin-left: 10rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.sp-mini-btn::after {
  border: none;
}

.sp-mini-btn:active {
  transform: scale(0.96);
  background: rgba(255, 255, 255, 0.12);
}

.sp-mini-btn-primary {
  border-color: rgba(16, 185, 129, 0.5);
  color: #10b981;
  background: rgba(16, 185, 129, 0.1);
  box-shadow: 0 4rpx 12rpx rgba(16, 185, 129, 0.2);
}

.sp-chip-grid {
  display: flex;
  flex-wrap: wrap;
  margin: 0 -8rpx;
}

.sp-chip {
  width: calc(50% - 16rpx);
  margin: 0 8rpx 16rpx;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.03);
  color: #fafafa;
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.05), 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
  padding: 0;
  transition: all 180ms ease;
}

.sp-chip::after {
  border: none;
}

.sp-chip:active {
  transform: scale(0.96);
  background: rgba(255, 255, 255, 0.08);
  box-shadow: inset 0 4rpx 8rpx rgba(0, 0, 0, 0.2);
}

.sp-chip[disabled] {
  opacity: 0.4;
  filter: grayscale(1);
}

.sp-chip.cold {
  border-color: rgba(6, 182, 212, 0.4);
  color: #06b6d4;
  background: linear-gradient(135deg, rgba(6, 182, 212, 0.1), rgba(0,0,0,0));
}

.sp-chip.rain {
  border-color: rgba(59, 130, 246, 0.4);
  color: #3b82f6;
  background: linear-gradient(135deg, rgba(59, 130, 246, 0.1), rgba(0,0,0,0));
}

.sp-chip.dry {
  border-color: rgba(245, 158, 11, 0.4);
  color: #f59e0b;
  background: linear-gradient(135deg, rgba(245, 158, 11, 0.1), rgba(0,0,0,0));
}

.sp-chip.fire {
  border-color: rgba(239, 68, 68, 0.4);
  color: #ef4444;
  background: linear-gradient(135deg, rgba(239, 68, 68, 0.15), rgba(0,0,0,0));
}

.sp-chip.gas {
  border-color: rgba(168, 85, 247, 0.4);
  color: #a855f7;
  background: linear-gradient(135deg, rgba(168, 85, 247, 0.1), rgba(0,0,0,0));
}

.sp-chip.leak {
  border-color: rgba(14, 165, 233, 0.4);
  color: #0ea5e9;
  background: linear-gradient(135deg, rgba(14, 165, 233, 0.1), rgba(0,0,0,0));
}

.sp-chip.outlier {
    width: calc(100% - 16rpx);
  color: #a1a1aa;
  background: linear-gradient(135deg, rgba(161, 161, 170, 0.1), rgba(0,0,0,0));
}

.sp-chip.stop {
  width: calc(100% - 16rpx);
  border-color: rgba(16, 185, 129, 0.5);
  color: #10b981;
  background: linear-gradient(135deg, rgba(16, 185, 129, 0.15), rgba(0,0,0,0));
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.05), 0 8rpx 16rpx rgba(16, 185, 129, 0.15);
}

.sp-alarm-scroll {
  max-height: 420rpx;
}

.sp-alarm-item {
  margin-bottom: 12rpx;
  padding: 14rpx 16rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.03);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  font-size: 19rpx;
  color: #a1a1aa;
  transition: transform 180ms ease;
}

.sp-alarm-item:last-child {
  margin-bottom: 0;
}

.sp-alarm-item.active {
  border-left: 6rpx solid #ef4444;
  background: linear-gradient(90deg, rgba(239, 68, 68, 0.08) 0%, rgba(255, 255, 255, 0.01) 100%);
}

.sp-alarm-item.resolved {
  border-left: 6rpx solid #10b981;
  background: linear-gradient(90deg, rgba(16, 185, 129, 0.08) 0%, rgba(255, 255, 255, 0.01) 100%);
}

.sp-alarm-line {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.sp-alarm-time {
  color: #ffffff;
  font-size: 18rpx;
}

.sp-alarm-tag {
  color: #ffffff;
  font-size: 17rpx;
}

.sp-alarm-reason,
.sp-alarm-disposal,
.sp-alarm-resolved {
  display: block;
  margin-top: 6rpx;
  line-height: 1.35;
}

.sp-alarm-resolved {
  color: #1ed760;
}

.sp-log-scroll {
  height: 292rpx;
  padding: 8rpx 6rpx;
}

.sp-log-item {
  padding: 10rpx 8rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
  font-size: 19rpx;
  color: #a1a1aa;
  line-height: 1.5;
}

.sp-log-item:last-child {
  border-bottom: none;
}

.sp-log-item.alert {
  color: #ef4444;
}

.sp-log-item.cool {
  color: #3b82f6;
}

.sp-empty {
  padding: 22rpx 0;
  text-align: center;
  color: #7c7c7c;
  font-size: 19rpx;
}
